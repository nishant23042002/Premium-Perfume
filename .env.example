MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/
MONGODB_DB_NAME=premium-perfume

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudinary — required for the admin upload panel
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Signs the httpOnly session cookie issued after phone OTP login — keep secret.
AUTH_SESSION_SECRET=

# Signs the separate admin-panel session cookie. The admin panel has its own
# email+password login (AdminUser model, role-based permissions) completely
# independent of customer auth above — bootstrap the first account with
# `npm run create-owner -- "Full Name" email@example.com "password"`.
ADMIN_SESSION_SECRET=

# Firebase Phone Auth — client (public) config, from Firebase Console > Project Settings
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK — service account (server-only, keep secret)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Razorpay — online payment at checkout. Key ID is also needed client-side
# (NEXT_PUBLIC_) to open the Checkout widget; the secret and webhook secret
# must stay server-only. Webhook secret is configured separately in the
# Razorpay Dashboard under Settings > Webhooks, pointed at
# /api/webhooks/razorpay.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_WEBHOOK_SECRET=

# Resend — sends the order confirmation email. Sign up free at resend.com.
# Without a verified sending domain, you can only send from
# onboarding@resend.dev to the email address on your own Resend account —
# fine for testing, not for real customers. Verify a domain (Resend
# Dashboard > Domains) before launch, then set RESEND_FROM_EMAIL to an
# address on it, e.g. "THE RARESKIN <orders@yourdomain.com>".
RESEND_API_KEY=
RESEND_FROM_EMAIL=
